APP_NAME=ZoSwi AI Interview API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000,https://zoswiai.vercel.app

# Local default uses SQLite for zero-setup development.
# For PostgreSQL, switch to:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/zoswi_interview
DATABASE_URL=sqlite+aiosqlite:///./zoswi_interview.db
REDIS_URL=redis://localhost:6379/0

AUTH_REQUIRED=false
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=zoswi-auth
JWT_AUDIENCE=zoswi-platform
WS_TOKEN_TTL_SECONDS=60

OPENAI_API_KEY=
OPENAI_API_SETTING_KEY=ZOSWI_AI_API_KEY
DB_API_KEY_CACHE_TTL_SECONDS=30
STT_MODEL=gpt-4o-mini-transcribe
STT_FALLBACK_MODELS=whisper-1
LLM_MODEL=gpt-4.1-mini
LLM_FALLBACK_MODELS=gpt-4o-mini
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=cedar

MAX_QUESTIONS_PER_INTERVIEW=5
ANSWER_TIME_LIMIT_SECONDS=120
INTERVIEW_DURATION_SECONDS=1800
STORAGE_DIR=storage
WS_EVENTS_PER_MINUTE=120
API_REQUESTS_PER_MINUTE=300
CANDIDATE_MAX_ACTIVE_INTERVIEWS=3
CANDIDATE_MAX_INTERVIEWS_TOTAL=3
CANDIDATE_MAX_INTERVIEWS_PER_DAY=10
RECRUITER_REVIEW_LIMIT_PER_MINUTE=50

TELEMETRY_ENABLED=false
TELEMETRY_SERVICE_NAME=zoswi-ai-interview-api
TELEMETRY_OTLP_ENDPOINT=
