[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace_with_a_long_random_secret"

[database]
# Required: set PostgreSQL URL for the app backend.
# url = "postgresql://pystreamline_app:your_password@localhost:5432/pystreamline"

[auth.google]
client_id = "replace_with_google_client_id"
client_secret = "replace_with_google_client_secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[auth.linkedin]
client_id = "replace_with_linkedin_client_id"
client_secret = "replace_with_linkedin_client_secret"
server_metadata_url = "https://www.linkedin.com/oauth/.well-known/openid-configuration"
client_kwargs = { scope = "openid profile email" }

[promo]
valid_codes = ["WELCOME2026", "EARLYACCESS"]
